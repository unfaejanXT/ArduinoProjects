/**
 * ============================================================
 *  FILE: config.h.example
 *  Deskripsi: Contoh file konfigurasi - SALIN ke config.h
 *  Project  : LCD Jam Digital PROSEDURAL - NodeMCU v3
 * ============================================================
 *
 *  CARA PENGGUNAAN:
 *  1. Salin file ini menjadi config.h
 *  2. Ganti WIFI_SSID dengan nama WiFi rumah Anda
 *  3. Ganti WIFI_PASSWORD dengan password WiFi rumah Anda
 *  4. Sesuaikan NTP_UTC_OFFSET jika beda zona waktu
 *     WIB  = 7  * 3600 = 25200
 *     WITA = 8  * 3600 = 28800
 *     WIT  = 9  * 3600 = 32400
 * ============================================================
 */

#ifndef CONFIG_H
#define CONFIG_H

// ─────────────────────────────────────────────
//  🔑 KONFIGURASI WIFI  ← UBAH BAGIAN INI
// ─────────────────────────────────────────────
#define WIFI_SSID       "NamaWiFiAnda"       // Ganti dengan SSID WiFi Anda
#define WIFI_PASSWORD   "PasswordWiFiAnda"   // Ganti dengan password WiFi Anda

// Timeout koneksi WiFi (dalam milidetik)
#define WIFI_TIMEOUT_MS  15000   // 15 detik

// ─────────────────────────────────────────────
//  🕐 KONFIGURASI NTP (Sinkronisasi Waktu)
// ─────────────────────────────────────────────
#define NTP_SERVER          "pool.ntp.org"    // Server NTP utama
#define NTP_SERVER_BACKUP   "time.google.com" // Server NTP cadangan
#define NTP_UTC_OFFSET      25200             // UTC+7 (WIB) = 7 * 3600
#define NTP_UPDATE_INTERVAL 3600000           // Update setiap 1 jam (ms)

// ─────────────────────────────────────────────
//  📺 KONFIGURASI OLED SSD1306
// ─────────────────────────────────────────────
#define OLED_SCREEN_WIDTH   128   // Lebar OLED dalam pixel
#define OLED_SCREEN_HEIGHT   64   // Tinggi OLED dalam pixel
#define OLED_ADDR          0x3C   // Alamat I2C OLED SSD1306
#define OLED_RESET_PIN       -1   // Reset pin (-1 = share reset Arduino)

// Pin I2C pada NodeMCU v3:
//   SDA → D2 (GPIO4)
//   SCL → D1 (GPIO5)

// ─────────────────────────────────────────────
//  ⚙️  KONFIGURASI APLIKASI
// ─────────────────────────────────────────────
#define SERIAL_BAUD_RATE    115200  // Kecepatan Serial Monitor
#define DISPLAY_REFRESH_MS     500  // Refresh tampilan setiap 500ms

#endif // CONFIG_H
